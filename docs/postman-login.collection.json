{
  "info": {
    "_postman_id": "8b5ce0c5-16c9-4b97-b5dc-3df53ce8f85c",
    "name": "Promotional Materials Portal - Login",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Login - Seeded Production User",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('returns HTTP 200', function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "",
              "const json = pm.response.json();",
              "",
              "pm.test('returns the expected success message', function () {",
              "  pm.expect(json.message).to.eql('Login successful.');",
              "});",
              "",
              "pm.test('returns a token and user payload', function () {",
              "  pm.expect(json).to.have.property('data');",
              "  pm.expect(json.data).to.have.property('token');",
              "  pm.expect(json.data.token).to.be.a('string').and.not.empty;",
              "  pm.expect(json.data).to.have.property('user');",
              "  pm.expect(json.data.user).to.have.property('email');",
              "  pm.expect(json.data.user.email).to.eql(pm.collectionVariables.get('email'));",
              "});",
              "",
              "pm.collectionVariables.set('authToken', json.data.token);"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Accept",
            "value": "application/json"
          },
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"{{email}}\",\n  \"password\": \"{{password}}\"\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "url": {
          "raw": "{{baseUrl}}/auth/login",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "auth",
            "login"
          ]
        },
        "description": "Logs in with the current seeded production account and stores the returned Sanctum token in `authToken`."
      },
      "response": []
    }
  ],
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://127.0.0.1:8000/api"
    },
    {
      "key": "email",
      "value": "production@example.com"
    },
    {
      "key": "password",
      "value": "password123"
    },
    {
      "key": "authToken",
      "value": ""
    }
  ]
}
